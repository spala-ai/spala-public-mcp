PORT=4100
PUBLIC_BASE_URL=https://mcp.spala.ai
# Internal control-plane origin, supplied by the hosted deployment. Do not publish it in public MCP metadata.
SPALA_API_BASE_URL=
PUBLIC_OAUTH_ENCRYPTION_SECRET=
# Dedicated persistent 0700 directory shared by every worker; never use the filesystem root.
PUBLIC_OAUTH_REPLAY_STATE_PATH=/var/lib/mcp-spala-ai/oauth-replay
PUBLIC_OAUTH_TICKET_LIFETIME_SECONDS=300
PUBLIC_OAUTH_CODE_LIFETIME_SECONDS=60
PUBLIC_OAUTH_ACCESS_TOKEN_LIFETIME_SECONDS=900
PUBLIC_OAUTH_REFRESH_TOKEN_LIFETIME_SECONDS=2592000
PUBLIC_OAUTH_CLIENT_LIFETIME_SECONDS=2592000
PUBLIC_OAUTH_RATE_LIMIT_MAX=120
SPALA_DASHBOARD_URL=https://dashboard.spala.ai
SPALA_PRICING_URL=https://spala.ai/pricing/
SPALA_DOCS_URL=https://docs.spala.ai/agents/mcp
CORS_ALLOWED_ORIGINS=https://app.spala.ai,https://spala.ai
FETCH_TIMEOUT_MS=8000
SPALA_API_RESPONSE_LIMIT_BYTES=1048576
MCP_BODY_LIMIT_BYTES=1048576
MCP_RATE_LIMIT_MAX=120
